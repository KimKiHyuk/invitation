# Kakao Maps JavaScript key from Kakao Developers
# Register the Vercel domain in Platform > Web.
VITE_KAKAO_MAP_APP_KEY=

# Optional webhook target for RSVP persistence.
# If empty, /api/rsvp stores entries in Vercel logs only.
RSVP_WEBHOOK_URL=

# Optional bearer token added when forwarding RSVP payloads.
RSVP_WEBHOOK_TOKEN=
