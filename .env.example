# Kakao Maps JavaScript key from Kakao Developers.
# Register your deployed site origin in Platform > Web if you enable the SDK again.
VITE_KAKAO_MAP_APP_KEY=

# Optional webhook target for RSVP persistence in non-static deployments.
RSVP_WEBHOOK_URL=

# Optional bearer token added when forwarding RSVP payloads.
RSVP_WEBHOOK_TOKEN=
