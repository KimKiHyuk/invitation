# Kakao JavaScript key for Kakao Talk Share.
# Register your deployed site origin in Kakao Developers > Platform > Web.
VITE_KAKAO_SDK_JS_KEY=

# Optional webhook target for RSVP persistence in non-static deployments.
RSVP_WEBHOOK_URL=

# Optional bearer token added when forwarding RSVP payloads.
RSVP_WEBHOOK_TOKEN=
